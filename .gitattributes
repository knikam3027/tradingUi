# Normalize line endings: LF in repo, checkout as-is on all platforms
* text=auto eol=lf

# Force LF for these file types always
*.js   text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.sh   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.conf text eol=lf
*.py   text eol=lf

# Binary files — no line-ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
